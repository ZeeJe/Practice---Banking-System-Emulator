@using BankingSystem.Domain.DTOs

<div class="modal @(isOpen ? "d-block" : "d-none")" style="@(isOpen ? "background-color: rgba(0,0,0,0.5);" : "")" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    @(isEditMode ? "✏️ Edit Customer" : "➕ Add New Customer")
                </h5>
                <button type="button" class="btn-close btn-close-white" @onclick="Close"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@editingCustomer" OnValidSubmit="@HandleSubmit" novalidate="novalidate">
                    <DataAnnotationsValidator />

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label for="fullName" class="form-label">Full Name *</label>
                        <InputText 
                            id="fullName" 
                            class="form-control" 
                            placeholder="Enter customer name"
                            @bind-Value="editingCustomer.FullName"
                            disabled="@isEditMode" />
                        <ValidationMessage For="@(() => editingCustomer.FullName)" class="text-danger small" />
                    </div>

                    <!-- Accounts Section -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <label class="form-label mb-0">
                                <strong>Accounts</strong>
                            </label>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddAccount">
                                <span class="bi bi-plus-circle"></span> Add Account
                            </button>
                        </div>

                        @if (editingCustomer.Accounts == null || editingCustomer.Accounts.Count == 0)
                        {
                            <div class="alert alert-info small">
                                No accounts yet. Click "Add Account" to create one.
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-3 bg-light">
                                @for (int i = 0; i < editingCustomer.Accounts.Count; i++)
                                {
                                    var account = editingCustomer.Accounts[i];
                                    <div class="row mb-3 align-items-end">
                                        <div class="col-md-6">
                                            <label class="form-label small">Account ID</label>
                                            <input type="text" class="form-control form-control-sm" 
                                                   placeholder="e.g., UA-FIAT-001"
                                                   @bind="account.AccountId" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small">Balance</label>
                                            <input type="number" class="form-control form-control-sm" 
                                                   placeholder="0.00" step="0.01"
                                                   @bind="account.Balance" />
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" class="btn btn-danger btn-sm w-100" 
                                                    @onclick="() => RemoveAccount(i)">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Summary -->
                    <div class="alert alert-secondary small">
                        <strong>Total Balance:</strong> ₴ @(editingCustomer.Accounts?.Sum(a => a.Balance) ?? 0).00
                    </div>

                    <!-- Form Actions -->
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="Close">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            @(isEditMode ? "Update Customer" : "Create Customer")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<CustomerDto> OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private bool isOpen = false;
    private bool isEditMode = false;
    private CustomerDto editingCustomer = new();

    public void Open(CustomerDto customer, bool isEdit)
    {
        isEditMode = isEdit;
        
        // Створюємо копію для редагування
        editingCustomer = new CustomerDto
        {
            FullName = customer.FullName,
            Accounts = customer.Accounts?.Select(a => new AccountDto 
            { 
                AccountId = a.AccountId, 
                Balance = a.Balance 
            }).ToList() ?? new List<AccountDto>()
        };

        isOpen = true;
        StateHasChanged();
    }

    public void Close()
    {
        isOpen = false;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(editingCustomer.FullName))
        {
            return;
        }

        await OnSave.InvokeAsync(editingCustomer);
        isOpen = false;
        StateHasChanged();
    }

    private void AddAccount()
    {
        editingCustomer.Accounts ??= new List<AccountDto>();
        editingCustomer.Accounts.Add(new AccountDto { AccountId = "", Balance = 0m });
    }

    private void RemoveAccount(int index)
    {
        if (editingCustomer.Accounts != null && index >= 0 && index < editingCustomer.Accounts.Count)
        {
            editingCustomer.Accounts.RemoveAt(index);
        }
    }
}
