@page "/customers"
@rendermode InteractiveServer
@inject CustomerService CustomerService

<PageTitle>Customers - Banking System</PageTitle>

<div class="container-fluid mt-5">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="display-6">
                <span class="badge bg-primary">💰 Customers Management</span>
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-success btn-lg" @onclick="OpenAddModal">
                <span class="bi bi-plus-circle"></span> Add New Customer
            </button>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="row">
        <div class="col-12">
            @if (customers == null)
            {
                <div class="alert alert-info">
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    Loading customers...
                </div>
            }
            else if (customers.Count == 0)
            {
                <div class="alert alert-warning">
                    <strong>No customers found!</strong> Click "Add New Customer" to create one.
                </div>
            }
            else
            {
                <div class="table-responsive shadow-sm rounded">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th class="text-center">Accounts</th>
                                <th class="text-end">Total Balance</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in customers)
                            {
                                var totalBalance = customer.Accounts?.Sum(a => a.Balance) ?? 0;
                                <tr>
                                    <td class="ps-4 align-middle">
                                        <strong>@customer.FullName</strong>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge bg-info text-dark">@(customer.Accounts?.Count ?? 0)</span>
                                    </td>
                                    <td class="text-end align-middle">
                                        <span class="badge bg-success fs-6">₴ @totalBalance.ToString("N0")</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <button class="btn btn-sm btn-primary" title="Edit" @onclick="() => OpenEditModal(customer)">
                                            <span class="bi bi-pencil"></span> Edit
                                        </button>
                                        <button class="btn btn-sm btn-danger" title="Delete" @onclick="() => ConfirmDelete(customer)">
                                            <span class="bi bi-trash"></span> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Add/Edit Modal -->
    <CustomerModal 
        @ref="modalComponent"
        OnSave="HandleSave"
        OnCancel="CloseModal" />

    <!-- Delete Confirmation Modal -->
    @if (showDeleteConfirm && customerToDelete != null)
    {
        <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteConfirm = false"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete customer <strong>@customerToDelete.FullName</strong>?</p>
                        <p class="text-muted small">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancel</button>
                        <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAction">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CustomerDto> customers = new();
    private CustomerModal? modalComponent;
    private bool showDeleteConfirm = false;
    private CustomerDto? customerToDelete;
    private bool isEditMode = false;
    private string? editingCustomerName;

    protected override void OnInitialized()
    {
        LoadCustomers();
    }

    private void LoadCustomers()
    {
        customers = CustomerService.GetAllCustomers();
    }

    private void OpenAddModal()
    {
        isEditMode = false;
        editingCustomerName = null;
        modalComponent?.Open(new CustomerDto { Accounts = new List<AccountDto>() }, isEdit: false);
    }

    private void OpenEditModal(CustomerDto customer)
    {
        isEditMode = true;
        editingCustomerName = customer.FullName;
        modalComponent?.Open(customer, isEdit: true);
    }

    private void HandleSave(CustomerDto customer)
    {
        if (isEditMode && editingCustomerName != null)
        {
            CustomerService.UpdateCustomer(editingCustomerName, customer);
        }
        else
        {
            CustomerService.AddCustomer(customer);
        }

        LoadCustomers();
        CloseModal();
    }

    private void CloseModal()
    {
        modalComponent?.Close();
    }

    private void ConfirmDelete(CustomerDto customer)
    {
        customerToDelete = customer;
        showDeleteConfirm = true;
    }

    private void ConfirmDeleteAction()
    {
        if (customerToDelete != null)
        {
            CustomerService.DeleteCustomer(customerToDelete.FullName);
            LoadCustomers();
        }

        showDeleteConfirm = false;
        customerToDelete = null;
    }
}

