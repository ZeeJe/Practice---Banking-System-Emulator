    private string transferType = "local";

    protected override void OnInitialized()
    {
        LoadStatistics();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize Bootstrap modals after Blazor renders
            await Task.Delay(100);
        }
    }

    private void LoadStatistics()
    {
        var customers = CustomerService.GetAllCustomers();
        
        statistics = new SystemStatistics
        {
            CustomersCount = customers.Count,
            TotalAccounts = customers.Sum(c => c.Accounts?.Count ?? 0),
            TotalBalance = customers.Sum(c => c.Accounts?.Sum(a => a.Balance) ?? 0)
        };
    }

    private class SystemStatistics
    {
        public int CustomersCount { get; set; }
        public int TotalAccounts { get; set; }
        public decimal TotalBalance { get; set; }
    }
}

